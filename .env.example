# ---- Server ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ---- Database ----
MONGODB_URI=

# ---- CORS ----
CLIENT_URL=http://localhost:3000

# ---- JWT ----
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- OTP ----
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=40
OTP_MAX_ATTEMPTS=5

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---- Mailer (Resend) ----
RESEND_API_KEY=re_your_api_key
MAIL_FROM=Autodhun <help@autodhun.com>

# ---- Rate Limit ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ---- Seeder Defaults ----
SUPER_ADMIN_EMAIL=superadmin@autodhun.com
SUPER_ADMIN_PASSWORD=Super@123
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# ---- Cloudinary (profile image uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
