# ---- Server ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ---- Database ----
MONGODB_URI=mongodb+srv://autodhundigital_db_user:0p68lY7gbyKHCJuV@cluster0.qo9s5eo.mongodb.net/autodhun_admin

# ---- CORS ----
CLIENT_URL=http://localhost:3000

# ---- JWT ----
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- OTP ----
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=40
OTP_MAX_ATTEMPTS=5

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---- Mailer (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM_NAME=Autodhun Admin
MAIL_FROM_EMAIL=no-reply@autodhun.com

# ---- Rate Limit ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ---- Seeder Defaults ----
SUPER_ADMIN_EMAIL=superadmin@autodhun.com
SUPER_ADMIN_PASSWORD=Super@123
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# ---- Cloudinary (profile image uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
